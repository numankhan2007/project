# ===== DATABASE CONFIGURATION =====
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/unimart_local

# ===== DATABASE CREATION (used by create_db.py) =====
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=YOUR_PASSWORD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unimart_local

# ===== REDIS CONFIGURATION =====
REDIS_URL=redis://localhost:6379/0

# ===== JWT SECURITY =====
# Generate secure keys with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MINIMUM 32 bytes required for SHA256 security
SECRET_KEY=your-super-secret-key-here-minimum-32-chars

# ===== SMTP EMAIL SERVICE =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ===== ADMIN CREDENTIALS (DB-backed admin username & password, NOT plaintext key) =====
ADMIN_USERNAME=admin123
ADMIN_PASSWORD=admin123

# ===== API SERVER CONFIGURATION =====
API_HOST=0.0.0.0
API_PORT=8000

# ===== CORS CONFIGURATION =====
# Comma-separated list of additional allowed origins (production URLs)
# Default development origins (localhost:5173, localhost:3000) are always allowed
CORS_ORIGINS=https://your-production-domain.com,https://www.your-domain.com

# ===== ADMIN JWT (separate from student JWT) =====
# Generate secure keys with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MINIMUM 32 bytes required for SHA256 security
ADMIN_JWT_SECRET=change-this-admin-jwt-secret-in-production
ADMIN_DISPLAY_NAME=Super Admin

# ===== REFRESH TOKEN (NEW) =====
# Generate secure keys with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MINIMUM 32 bytes required for SHA256 security
REFRESH_TOKEN_SECRET=change-this-refresh-secret-in-production

# ===== CLOUDINARY IMAGE UPLOAD =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
