# ===== DATABASE CONFIGURATION =====
# PostgreSQL connection string - REQUIRED
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://unimart_user:your_secure_password_here@localhost:5432/unimart

# ===== REDIS CONFIGURATION =====
# Redis connection - REQUIRED for OTP verification and session management
# Format: redis://host:port/db_number
REDIS_URL=redis://localhost:6379/0

# ===== JWT SECURITY =====
# Secret key for JWT token signing - REQUIRED
# Generate a strong random string using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# For production, use a minimum 32-character random string
SECRET_KEY=your-super-secret-key-here-minimum-32-chars-generate-a-random-one

# ===== SENDGRID EMAIL SERVICE =====
# SendGrid API Key - Required for registration OTP emails
# Get this from: https://app.sendgrid.com/settings/api_keys
# Format: SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# SendGrid verified sender email - must be verified in SendGrid dashboard
# This email will appear in the "From" field of OTP emails
SENDGRID_FROM_EMAIL=noreply@unimart.com

# ===== API SERVER CONFIGURATION =====
# Host to bind the FastAPI server to
API_HOST=0.0.0.0

# Port to run the FastAPI server on
API_PORT=8000

# ===== OPTIONAL: ENVIRONMENT TYPE =====
# Set to 'development' or 'production'
# ENVIRONMENT=development
